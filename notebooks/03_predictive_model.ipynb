{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Predictive Layer — REAL Bangalore rainfall panel\n",
    "\n",
    "Trains a LightGBM regressor on the **real rainfall panel** from\n",
    "OpenCity / Janaagraha (sibling repo `community-hero/data`):\n",
    "\n",
    "- `data/raw/rain_panel.csv` — 14,580 rows of (month, ward, ward_no, road_complaints) for 243 wards × 60 months (2021-01 → 2025-12)\n",
    "- `data/raw/rainfall.csv`   — 60 months of Bangalore aggregate rainfall in mm\n",
    "- ward centroids extracted from `community-hero/data/ward_backlog.json` (real KGIS)\n",
    "\n",
    "Specification (matches the reference implementation):\n",
    "\n",
    "```\n",
    "log(road_complaints + 1) ~ ward_FE + month_FE + rain + rain_lag1\n",
    "```\n",
    "\n",
    "Output → `data/processed/hotspots.geojson` consumed by the `/map` heatmap layer."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json, pathlib\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import lightgbm as lgb\n",
    "from sklearn.metrics import mean_absolute_error, r2_score\n",
    "\n",
    "DATA = pathlib.Path('../data')\n",
    "\n",
    "panel = pd.read_csv(DATA / 'raw' / 'rain_panel.csv')\n",
    "rain  = pd.read_csv(DATA / 'raw' / 'rainfall.csv')\n",
    "\n",
    "print(f'panel : {len(panel):,} ward-months, {panel.ward.nunique()} wards, '\n",
    "      f'months {panel.month.min()} → {panel.month.max()}')\n",
    "print(f'rain  : {len(rain):,} months')\n",
    "panel.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Join rainfall onto the panel and build the rain_lag1 feature.\n",
    "rain = rain.sort_values('month').reset_index(drop=True)\n",
    "rain['rain_lag1'] = rain['rain_mm'].shift(1).fillna(rain['rain_mm'].iloc[0])\n",
    "\n",
    "df = panel.merge(rain, on='month', how='left')\n",
    "df['month_dt'] = pd.to_datetime(df['month'] + '-01')\n",
    "df['month_of_year'] = df['month_dt'].dt.month\n",
    "df['year'] = df['month_dt'].dt.year\n",
    "df['log_y'] = np.log1p(df['road_complaints'])\n",
    "\n",
    "# Ward fixed effects via integer codes.\n",
    "df['ward_code'] = df['ward'].astype('category').cat.codes\n",
    "\n",
    "FEATURES = ['ward_code', 'month_of_year', 'rain_mm', 'rain_lag1']\n",
    "\n",
    "# Out-of-sample split: latest year is test, earlier years train.\n",
    "test_year = df['year'].max()\n",
    "train = df[df['year'] < test_year]\n",
    "test  = df[df['year'] == test_year]\n",
    "\n",
    "print(f'train: {len(train):,} rows  ({sorted(train.year.unique())})')\n",
    "print(f'test : {len(test):,} rows   ({test_year})')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = lgb.LGBMRegressor(\n",
    "    n_estimators=600, learning_rate=0.05, num_leaves=63,\n",
    "    min_child_samples=20, subsample=0.9, colsample_bytree=0.9,\n",
    "    random_state=7,\n",
    ")\n",
    "model.fit(\n",
    "    train[FEATURES], train['log_y'],\n",
    "    eval_set=[(test[FEATURES], test['log_y'])],\n",
    "    callbacks=[lgb.early_stopping(30)],\n",
    ")\n",
    "\n",
    "pred_log = model.predict(test[FEATURES])\n",
    "pred = np.expm1(pred_log)\n",
    "actual = test['road_complaints'].values\n",
    "\n",
    "print(f'\\nMAE (counts)  : {mean_absolute_error(actual, pred):.2f}')\n",
    "print(f'R²  (log-scale): {r2_score(test[\"log_y\"], pred_log):.3f}')\n",
    "print(f'R²  (counts)  : {r2_score(actual, pred):.3f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Pull real KGIS ward centroids from the community-hero ward_backlog.json\n",
    "wb_path = pathlib.Path('../../community-hero/data/ward_backlog.json')\n",
    "ward_xy = {w['ward']: (w['lon'], w['lat']) for w in json.loads(wb_path.read_text())['wards']}\n",
    "print(f'centroids for {len(ward_xy):,} wards')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Forecast next month: assume rain ≈ same as last observed month + same lag.\n",
    "last = df.sort_values('month_dt').iloc[-1]\n",
    "next_month_of_year = (last.month_of_year % 12) + 1\n",
    "next_rain = float(last.rain_mm)\n",
    "next_rain_lag = float(last.rain_mm)\n",
    "\n",
    "wards = df[['ward','ward_code']].drop_duplicates().reset_index(drop=True)\n",
    "wards['month_of_year'] = next_month_of_year\n",
    "wards['rain_mm']  = next_rain\n",
    "wards['rain_lag1'] = next_rain_lag\n",
    "wards['risk_log'] = model.predict(wards[FEATURES])\n",
    "wards['predicted_complaints'] = np.expm1(wards['risk_log']).clip(0)\n",
    "wards['risk_norm'] = (wards['predicted_complaints'] - wards['predicted_complaints'].min()) / (wards['predicted_complaints'].max() - wards['predicted_complaints'].min() + 1e-9)\n",
    "wards = wards.sort_values('predicted_complaints', ascending=False)\n",
    "wards.head(10)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build the GeoJSON heatmap source — one point per ward centroid, top 150 ranked.\n",
    "out = pathlib.Path('../data/processed/hotspots.geojson')\n",
    "out.parent.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "top = wards.head(150)\n",
    "features = []\n",
    "for r in top.itertuples():\n",
    "    xy = ward_xy.get(r.ward)\n",
    "    if xy is None:\n",
    "        continue\n",
    "    features.append({\n",
    "        'type': 'Feature',\n",
    "        'geometry': {'type': 'Point', 'coordinates': [xy[0], xy[1]]},\n",
    "        'properties': {\n",
    "            'ward': r.ward,\n",
    "            'risk': round(float(r.risk_norm), 3),\n",
    "            'predicted_30d': round(float(r.predicted_complaints), 1),\n",
    "            'horizon_days': 30,\n",
    "            'drivers': {'rain_mm': next_rain, 'rain_lag1_mm': next_rain_lag, 'month': next_month_of_year},\n",
    "        },\n",
    "    })\n",
    "\n",
    "fc = {'type': 'FeatureCollection', 'features': features}\n",
    "out.write_text(json.dumps(fc))\n",
    "print(f'wrote {len(features)} hotspots → {out}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Feature importance — useful for the pitch slide.\n",
    "imp = pd.DataFrame({'feature': FEATURES, 'importance': model.feature_importances_}).sort_values('importance', ascending=False)\n",
    "imp"
   ]
  }
 ],
